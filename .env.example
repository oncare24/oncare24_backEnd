# ===========================
# Database (MySQL)
# ===========================
MYSQL_ROOT_PASSWORD=root1234
MYSQL_DATABASE=oncare
MYSQL_USER=oncare
MYSQL_PASSWORD=oncare1234

# ===========================
# JWT
# 운영 환경에서는 반드시 변경 (256비트 이상 권장)
# 생성 예: openssl rand -base64 64
# ===========================
JWT_SECRET=dev-only-secret-please-change-this-key-must-be-at-least-256-bits-long-for-hs256

# ===========================
# Spring Profile
# dev | prod
# ===========================
SPRING_PROFILES_ACTIVE=dev

# ===========================
# Redis (옵션 - 도커 사용 시 기본값 OK)
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
